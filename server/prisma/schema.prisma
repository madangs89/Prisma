generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id         String   @id @default(uuid())
  name       String   @unique @db.VarChar(255)
  code       String   @unique @db.VarChar(255)
  hod_id     String?
  hod        User?    @relation("DepartmentHOD", fields: [hod_id], references: [id])
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  branches   Branch[]
  user       User[]   @relation("DepartmentUsers")
}

model Branch {
  id              String           @id @default(uuid())
  department_id   String
  department      Department       @relation(fields: [department_id], references: [id])
  name            String           @unique @db.VarChar(255)
  code            String           @unique @db.VarChar(255)
  is_active       Boolean          @default(true)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  specializations Specialization[]
}

model Specialization {
  id            String   @id @default(uuid())
  branch_id     String
  branch        Branch   @relation(fields: [branch_id], references: [id])
  name          String   @unique @db.VarChar(255)
  code          String   @unique @db.VarChar(255)
  is_active     Boolean  @default(true)
  duration_year Int      @default(4)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  batches  Batches[]
  subjects Subjects[]
}

model User {
  id                String       @id @default(uuid())
  name              String       @db.VarChar(255)
  email             String       @unique @db.VarChar(255)
  password_hash     String       @db.VarChar(255)
  usn               String       @unique @db.VarChar(255)
  employee_id       String       @unique @db.VarChar(255)
  phone             String       @unique @db.VarChar(255)
  department_id     String
  department        Department?  @relation("DepartmentUsers", fields: [department_id], references: [id])
  hod_of            Department[] @relation("DepartmentHOD")
  profile_photo_url String?      @db.VarChar(500)
  status            String       @default("active") // active, inactive, suspended
  last_login_at     DateTime?    @db.Timestamp(3)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  roles        UserRoles[]
  grantedRoles UserRoles[] @relation("GrantedBy")

  @@index([department_id])
  @@index([status])
  @@index([status, department_id])
}

model UserRoles {
  id   String @id @default(uuid())
  role String @default("student") @db.VarChar(30)

  user_id    String   @unique
  user       User     @relation(fields: [user_id], references: [id])
  granted_by String
  grantedBy  User     @relation("GrantedBy", fields: [granted_by], references: [id])
  granted_at DateTime @default(now())
}

model AcademicCycles {
  id         String     @id @default(uuid())
  name       String     @unique @db.VarChar(255)
  start_date DateTime
  end_date   DateTime
  is_active  Boolean    @default(true)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  sections   Sections[]
}

model Batches {
  id                String         @id @default(uuid())
  label             String         @unique @db.VarChar(255)
  start_year        Int
  end_year          Int
  is_active         Boolean        @default(true)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  specialization_id String
  specialization    Specialization @relation(fields: [specialization_id], references: [id])
  section           Sections[]
  @@unique([start_year, end_year, specialization_id])
  @@index([specialization_id])
}


model Sections {
  id                String         @id @default(uuid())
  name              String         @unique @db.VarChar(255)
  batch_id          String
  batch             Batches        @relation(fields: [batch_id], references: [id])
  academic_cycle_id String
  academic_cycle    AcademicCycles @relation(fields: [academic_cycle_id], references: [id])
  @@unique([batch_id, academic_cycle_id, name])
  @@index([batch_id])
  @@index([academic_cycle_id, batch_id])
}

model Subjects {
  id                String         @id @default(uuid())
  name              String         @unique @db.VarChar(255)
  code              String         @unique @db.VarChar(255)
  specialization_id String
  specialization    Specialization @relation(fields: [specialization_id], references: [id])
  thumbnail_url     String?        @db.VarChar(500)
  year              Int
  semester          Int
  credits           Int            @default(3)
  type              String         @db.VarChar(50) // theory, practical, project
  is_active         Boolean        @default(true)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  @@index([specialization_id])
  @@index([specialization_id, year])
}




